import java.util.LinkedList;

public class GenericSearch {

    // Generic method to search element in LinkedList
    public static <T> boolean searchElement(LinkedList<T> list, T element) {
        return list.contains(element);
    }

    public static void main(String[] args) {

        // LinkedList of Integers (Roll Numbers)
        LinkedList<Integer> rollNumbers = new LinkedList<>();
        rollNumbers.add(101);
        rollNumbers.add(102);
        rollNumbers.add(103);
        rollNumbers.add(104);

        // Search in Integer list
        System.out.println("Roll number 103 found? " +
                searchElement(rollNumbers, 103));

        System.out.println("Roll number 999 found? " +
                searchElement(rollNumbers, 999));

        // LinkedList of Strings (Names)
        LinkedList<String> names = new LinkedList<>();
        names.add("Amit");
        names.add("Riya");
        names.add("John");
        names.add("Sara");

        // Search in String list
        System.out.println("\nName 'Riya' found? " +
                searchElement(names, "Riya"));

        System.out.println("Name 'David' found? " +
                searchElement(names, "David"));
    }
}
